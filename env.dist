# Copy to .env and fill in your values:  cp env.dist .env

# --- App ---
PORT=3005

# --- Cloudflare R2 (S3-compatible keys and bucket) ---
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=my-bucket
R2_BUCKET=my-bucket
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Public base for download links (used by the copy button), no trailing slash
PUBLIC_DOWNLOAD_BASE=https://dl.example.com/download

# --- Deploy (used by `npm run deploy` / gulpfile.js) ---
DEPLOY_HOSTNAME=root@203.0.113.10
DEPLOY_DESTINATION=/var/www/storage.example.com
DEPLOY_SERVICE=r2-manager
DEPLOY_OWNER=www-data:www-data
